<h2 class="mt-3">entries for {{date}}</h2>

<form method="GET" action="/" class="row g-2 align-items-end mb-3">
  <div class="col-auto">
    <label class="form-label">date:</label>
    <input type="date" class="form-control form-control-sm" name="date" value="{{date}}">
  </div>
  <div class="col-auto">
    <button type="submit" class="btn btn-primary btn-sm">go</button>
  </div>
</form>

{{#if goal}}
<div class="goal-box">
  <p>goal: <strong>{{goal}} cals</strong></p>
  <p>eaten so far: <strong>{{total}} cals</strong></p>
  {{#if overGoal}}
    <p class="over">⚠️ you went over by {{overBy}} cals... rip</p>
  {{else}}
    <p class="under">{{remaining}} cals left, you got this</p>
  {{/if}}
</div>
{{/if}}

{{#if entries.length}}
<table class="table table-hover">
  <thead>
    <tr>
      <th>food</th>
      <th>cals</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
  {{#each entries}}
  <tr>
    <td>{{this.food}}</td>
    <td>{{this.calories}}</td>
    <td>
      <a href="/edit/{{this._id}}" class="btn btn-sm btn-outline-secondary me-1">✏️</a>
      <form method="POST" action="/delete/{{this._id}}" style="display:inline;">
        <button class="btn btn-danger btn-sm del-btn" type="submit">x</button>
      </form>
    </td>
  </tr>
  {{/each}}
  </tbody>
</table>
<p class="fw-bold">total: {{total}} calories</p>
{{else}}
<p>no entries yet for this day. go add some food!</p>
{{/if}}

<!--
  research topic: chart.js (3 points)
  bar chart showing calories per food entry for the selected day
  reference: https://www.chartjs.org/docs/latest/getting-started/
-->
{{#if entries.length}}
<div class="chart-wrap">
  <h5>breakdown</h5>
  <canvas id="calChart" width="400" height="200"></canvas>
</div>
<script>
// chart.js integration - took me a while to get this working ngl
// basically just grabs the food names and calorie values
// and throws them into a bar chart
const labels = {{{chartLabels}}};
const data = {{{chartData}}};

// some green colors i picked to match the theme
// cycles thru if theres more than 6 entries
const colors = [
  'rgba(46, 125, 50, 0.6)',
  'rgba(67, 160, 71, 0.6)',
  'rgba(129, 199, 132, 0.6)',
  'rgba(200, 230, 201, 0.8)',
  'rgba(27, 94, 32, 0.6)',
  'rgba(76, 175, 80, 0.6)'
];

// pick colors for each bar, wraps around if needed
const barColors = data.map((_, i) => colors[i % colors.length]);

const ctx = document.getElementById('calChart').getContext('2d');
new Chart(ctx, {
  type: 'bar',
  data: {
    labels: labels,
    datasets: [{
      label: 'calories',
      data: data,
      backgroundColor: barColors,
      borderColor: barColors.map(c => c.replace('0.6', '1').replace('0.8', '1')),
      borderWidth: 1
    }]
  },
  options: {
    responsive: true,
    scales: {
      y: {
        beginAtZero: true,
        title: { display: true, text: 'cals' }
      }
    },
    plugins: {
      legend: { display: false }
    }
  }
});
</script>
{{/if}}
