<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>calorie tracker</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 30px auto;
      max-width: 580px;
      padding: 0 15px;
      background: #fafafa;
      color: #333;
    }
    h1 { margin-bottom: 5px; }
    h2 { color: #444; }
    h3 { margin-bottom: 6px; color: #555; }
    nav a { margin-right: 12px; text-decoration: none; color: #1a73e8; }
    nav a:hover { text-decoration: underline; }
    hr { margin: 10px 0; border: none; border-top: 1px solid #ddd; }

    table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    th, td { text-align: left; padding: 6px 8px; border-bottom: 1px solid #e0e0e0; }
    th { font-size: 13px; color: #777; text-transform: uppercase; }

    input, button { padding: 6px 10px; margin: 3px 0; }
    input[type="text"], input[type="number"], input[type="date"] {
      width: 100%; box-sizing: border-box; border: 1px solid #ccc; border-radius: 3px;
    }
    button {
      background: #1a73e8; color: white; border: none;
      border-radius: 3px; cursor: pointer; font-size: 13px; padding: 7px 14px;
    }
    button:hover { background: #1557b0; }

    .err { color: #d93025; margin: 8px 0; }
    .ok { color: #188038; margin: 8px 0; }
    .total { font-weight: bold; margin-top: 8px; }

    .del-btn {
      background: #ea4335; color: white; border: none;
      cursor: pointer; font-size: 11px; padding: 3px 8px; border-radius: 2px;
    }
    .del-btn:hover { background: #c5221f; }

    .goal-box {
      background: #e8f0fe;
      border-left: 3px solid #1a73e8;
      padding: 10px 14px;
      margin: 12px 0;
      border-radius: 4px;
    }
    .goal-box p { margin: 4px 0; }
    .over { color: #d93025; font-weight: bold; }
    .under { color: #188038; }

    .chart-wrap {
      margin-top: 20px;
      padding: 12px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 4px;
    }

    label { display: block; margin-top: 8px; font-size: 14px; color: #555; }
    form { margin: 10px 0; }
  </style>

  <!-- research topic: chart.js for visualizing calories -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <h1>🍔 calorie tracker</h1>
  <nav>
    <a href="/">home</a> |
    <a href="/add">+ add food</a> |
    <a href="/goal">🎯 set goal</a>
  </nav>
  <hr>
  {{{body}}}
</body>
</html>
