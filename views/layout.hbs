<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>calorie tracker</title>

  <!-- research topic: bootstrap 5 css framework (2 pts) with custom theme -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --bs-primary: #2e7d32;
      --bs-primary-rgb: 46, 125, 50;
      --accent: #43a047;
      --accent-light: #e8f5e9;
      --danger: #c62828;
    }
    body {
      background: #f5f7f5;
      font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
      color: #333;
    }
    .navbar {
      background: linear-gradient(135deg, #2e7d32, #43a047) !important;
    }
    .navbar-brand, .nav-link { color: #fff !important; }
    .nav-link:hover { color: #e8f5e9 !important; }
    .main-wrap {
      max-width: 640px;
      margin: 28px auto;
      padding: 0 16px;
    }
    .btn-primary {
      background-color: var(--accent);
      border-color: var(--accent);
    }
    .btn-primary:hover {
      background-color: #388e3c;
      border-color: #388e3c;
    }
    .btn-danger {
      background-color: var(--danger);
      border-color: var(--danger);
    }
    .goal-box {
      background: var(--accent-light);
      border-left: 4px solid var(--accent);
      padding: 12px 16px;
      margin: 14px 0;
      border-radius: 6px;
    }
    .goal-box p { margin: 4px 0; }
    .over { color: var(--danger); font-weight: bold; }
    .under { color: #2e7d32; }
    .chart-wrap {
      margin-top: 22px;
      padding: 14px;
      background: #fff;
      border: 1px solid #e0e0e0;
      border-radius: 6px;
    }
    .del-btn {
      font-size: 11px;
      padding: 2px 8px;
    }
    .search-results {
      max-height: 200px;
      overflow-y: auto;
      border: 1px solid #ccc;
      border-radius: 4px;
      display: none;
    }
    .search-result-item {
      padding: 8px 12px;
      cursor: pointer;
      border-bottom: 1px solid #eee;
      font-size: 14px;
    }
    .search-result-item:hover {
      background: var(--accent-light);
    }
    .search-result-item small {
      color: #777;
    }
    footer {
      text-align: center;
      margin-top: 40px;
      padding: 16px;
      color: #999;
      font-size: 13px;
    }
  </style>

  <!-- research topic: chart.js for visualizing calories (3 pts) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
  <nav class="navbar navbar-expand-sm navbar-dark">
    <div class="container-fluid" style="max-width:640px;">
      <a class="navbar-brand" href="/">🥗 calorie tracker</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/">home</a>
        <a class="nav-link" href="/add">+ add food</a>
        <a class="nav-link" href="/goal">set goal</a>
      </div>
    </div>
  </nav>

  <div class="main-wrap">
    {{{body}}}
  </div>

  <footer>calorie tracker &middot; built with express + mongodb</footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
