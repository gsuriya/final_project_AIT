<h2 class="mt-3">set calorie goal</h2>

{{#if error}}
  <p class="text-danger">{{error}}</p>
{{/if}}

{{#if success}}
  <p class="text-success">{{success}}</p>
{{/if}}

<form method="POST" action="/goal">
  <div class="mb-3">
    <label class="form-label">which day?</label>
    <input type="date" class="form-control" name="date" value="{{today}}" required>
  </div>

  <div class="mb-3">
    <label class="form-label">how many cals you tryna eat?</label>
    <input type="number" class="form-control" name="calorieGoal" min="0" placeholder="ex: 2000" value="{{currentGoal}}" required>
  </div>

  <button type="submit" class="btn btn-primary">save goal</button>
</form>

{{#if currentGoal}}
<p style="margin-top:14px; color:#555;">current goal for {{today}}: <strong>{{currentGoal}} cals</strong></p>
{{/if}}
