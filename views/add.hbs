<h2>add food</h2>

{{#if error}}
  <p class="err">{{error}}</p>
{{/if}}

<form method="POST" action="/add">
  <label>what did you eat?</label>
  <input type="text" name="food" placeholder="ex: chicken sandwich" required>

  <label>how many calories?</label>
  <input type="number" name="calories" min="0" placeholder="ex: 350" required>

  <label>when?</label>
  <input type="date" name="date" value="{{today}}" required>

  <br><br>
  <button type="submit">add entry</button>
</form>

<p style="margin-top:16px;font-size:13px;color:#888;">not sure about calories? just guess, close enough is fine lol</p>
